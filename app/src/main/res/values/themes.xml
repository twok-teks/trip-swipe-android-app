<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TripSwipe" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/plum_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/pink_300</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialButtonStyle">@style/Widget.TripSwipe.PrimaryButton</item>
        <item name="chipStyle">@style/Widget.TripSwipe.FilterChip</item>
    </style>

    <style name="Widget.TripSwipe.PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/plum_700</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.TripSwipe.SoftButton" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/lavender_200</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:textColor">@color/plum_800</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.TripSwipe.ImageNavButton" parent="Widget.Material3.Button.IconButton">
        <item name="backgroundTint">@color/white_35</item>
        <item name="rippleColor">@color/white_45</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.TripSwipe.FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/lavender_100</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/plum_800</item>
    </style>
</resources>
